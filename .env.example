# Database
POSTGRES_DB=security_analytics
POSTGRES_USER=security_user
POSTGRES_PASSWORD=security_pass

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
DEBUG=true
DATABASE_URL=postgresql+asyncpg://security_user:security_pass@postgres:5432/security_analytics

# Sniffer
INTERFACE=any
SIMULATION_MODE=auto
PACKET_BATCH_SIZE=100

# ML Worker
MODEL_UPDATE_INTERVAL=300
ANOMALY_THRESHOLD=0.7

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000